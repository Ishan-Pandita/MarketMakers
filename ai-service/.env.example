# Google Gemini API Key (free tier -- https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key

# Groq API Key (free tier -- https://console.groq.com/keys)
# If not set, chatbot will use Gemini only
GROQ_API_KEY=your_groq_api_key

# Twelve Data API Key (optional -- enables live prices)
# TWELVE_DATA_API_KEY=your_twelve_data_api_key

# Shared secret with backend (must match backend INTERNAL_TOKEN)
INTERNAL_TOKEN=<same-value-as-backend-INTERNAL_TOKEN>

# Server
PORT=8000
